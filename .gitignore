# Git ignore
__pycache__/
*.pyc
*.pyo
.env
.venv/
venv/
env/

# Vector store (committed to git so Streamlit Cloud has it on deploy)
# To exclude again: uncomment the line below
# data/chroma_db/

# Uploaded documents (sensitive)
data/raw/*.pdf

# Streamlit cache/secrets (keep config.toml tracked for Streamlit Cloud)
.streamlit/
!.streamlit/config.toml

# IDE
.vscode/
.idea/
*.egg-info/
dist/
build/
